<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/verse_widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bhagvad Gita"
            android:textAllCaps="true"
            android:textColor="#F4FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/widget_language"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/verse_widget_chip_background"
            android:paddingLeft="11dp"
            android:paddingTop="4dp"
            android:paddingRight="11dp"
            android:paddingBottom="4dp"
            android:text="English"
            android:textColor="#EEFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_reference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Chapter 1, Verse 1"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_verse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/verse_widget_verse_surface"
        android:ellipsize="end"
        android:fontFamily="serif"
        android:lineSpacingExtra="3dp"
        android:maxLines="8"
        android:padding="12dp"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/widget_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_gravity="end"
        android:text="Tap to open app"
        android:textColor="#A6FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.03" />
</LinearLayout>
